# PostgreSQL — local: docker compose (see docker-compose.yml)
# Cloud: https://neon.tech or https://supabase.com (use pooled connection string for serverless)
# No quotes on Windows so Prisma and shells parse this reliably
DATABASE_URL=postgresql://norfolk:norfolk@localhost:5432/ai_expenses?schema=public

# OpenAI: organization Costs + Completions Usage APIs (prefer admin key)
# https://platform.openai.com/settings/organization/admin-keys
# OPENAI_ADMIN_KEY=
OPENAI_API_KEY=
# Required if the key is in multiple orgs:
# OPENAI_ORG_ID=

# ChatGPT product (Plus / Business / etc.) — not the same as API usage; no public invoice API here.
# Set a monthly total to upsert one expense per calendar month via POST /api/sync/chatgpt
# CHATGPT_MONTHLY_USD=
# CHATGPT_CURRENCY=USD
# CHATGPT_MONTHLY_LABEL=ChatGPT Business — seats (example)
# CHATGPT_MONTHLY_NOTES=

# Perplexity — API key (same value you store in GitHub Secrets must also exist here or on Vercel for the app)
# PERPLEXITY_API_KEY=
# No org-wide billing HTTP API documented; monthly sync from numbers you read in the console:
# PERPLEXITY_MONTHLY_USD=
# PERPLEXITY_CURRENCY=USD
# PERPLEXITY_MONTHLY_LABEL=
# PERPLEXITY_MONTHLY_NOTES=

# Anthropic Claude API — Usage & Cost Admin API (org admin key, sk-ant-admin…)
# https://console.anthropic.com/settings/admin-keys
# ANTHROPIC_ADMIN_API_KEY=
# ANTHROPIC_API_KEY=   # only if this value is an Admin key (sync will fail otherwise)

# Google Cloud Billing export or API — use a service account JSON path in your host only; do not commit secrets
# GOOGLE_APPLICATION_CREDENTIALS=
