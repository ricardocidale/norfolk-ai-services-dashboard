generator client {
  provider = "prisma-client-js"
  // Outside node_modules so Windows AV / Node cannot lock the default query engine path during generate.
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BillingAccount {
  NORFOLK_GROUP
  NORFOLK_AI
  CIDALE
}

enum AiProvider {
  CURSOR
  ANTHROPIC
  OPENAI
  CHATGPT
  GOOGLE_API
  GOOGLE_WORKSPACE
  HUBSPOT
  GEMINI
  GEMINI_NANO_BANANA
  MANUS
  REPLIT
  VERCEL
  ELEVENLABS
  PERPLEXITY
  MIDJOURNEY
  AWS_BEDROCK
  MISTRAL
  COHERE
  FIGMA
  GITHUB
  LINEAR
  LOVABLE
  NETLIFY
  NOTION
  RAILWAY
  NEON
  AZURE
  CLERK
  STRIPE
  PLAID
  DROPBOX
  GOOGLE_CLOUD_STORAGE
  DOCSEND
  FLIPSNACK
  TWILIO
  RETELL_AI
  VONAGE
  OTHER
}

model Expense {
  id              String          @id @default(cuid())
  provider        AiProvider
  billingAccount  BillingAccount
  amount          Decimal         @db.Decimal(18, 4)
  currency        String          @default("USD")
  incurredAt      DateTime
  periodStart     DateTime?
  periodEnd       DateTime?
  label           String?
  notes           String?
  source          String          @default("manual")
  externalRef     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([incurredAt])
  @@index([provider])
  @@index([billingAccount])
  @@unique([provider, externalRef])
}

model SyncRun {
  id         String      @id @default(cuid())
  provider   AiProvider
  startedAt  DateTime    @default(now())
  finishedAt DateTime?
  ok         Boolean
  message    String?
  imported   Int         @default(0)
}

model GmailConnection {
  id           String    @id @default(cuid())
  email        String    @unique
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model EmailScanResult {
  id             String    @id @default(cuid())
  gmailEmail     String
  gmailMessageId String    @unique
  subject        String
  fromEmail      String
  receivedAt     DateTime
  parsedVendor   String?
  parsedAmount   Decimal?  @db.Decimal(18, 4)
  parsedCurrency String?
  parsedDate     DateTime?
  confidence     Float?
  parsedUsage    Json?
  status         String    @default("PENDING")
  expenseId      String?
  rawSnippet     String?
  createdAt      DateTime  @default(now())

  @@index([gmailEmail])
  @@index([status])
}
